class DosesController < ApplicationController
  @dose: (Dose | (Dose & Dose::Validated))?
  @vacina: (Vacina & Vacina::Validated)?
  def show: () -> void
  def new: () -> void
  def edit: () -> void
  def create: () -> void

  private

  def set_dose: () -> (Dose & Dose::Validated)
  def set_vacina: () -> (Vacina & Vacina::Validated)
  def dose_params: () -> untyped
end
