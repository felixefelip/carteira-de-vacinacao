class Current < ActiveSupport::CurrentAttributes
  @user: User?
  def self.user: () -> User?
  def self.user=: (User? value) -> User?
  def self.set: (?user: User?) ?{ (untyped) -> untyped } -> untyped
  def self.with: (?user: User?) ?{ (untyped) -> untyped } -> untyped
  def self.caderneta: () -> Caderneta?
  def user: () -> User?
  def user=: (User? value) -> User?
end
