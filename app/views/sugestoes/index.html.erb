<p id="notice"><%= notice %></p>

<h1>Calendário de Vacinação</h1>

<div class="age-info mb-4">
  <span>🎂 Idade atual: <%= Current.user!.idade_formatada %></span>
</div>

<div class="table-responsive-md">
  <table class="table table-striped table-bordered table-hover mt-4 shadow-sm">
    <thead class="thead-light">
      <tr>
        <th>Vacina</th>
        <th>Doses Tomadas</th>
        <th>Situação</th>
        <th>Ação</th>
      </tr>
    </thead>

    <tbody>
      <% @recomendacao_vacinas.each do |recomendacao_vacina| %>
        <%= render 'recomendacao_vacina', recomendacao_vacina: recomendacao_vacina %>
      <% end %>
    </tbody>
  </table>
</div>

<br>
<hr>
